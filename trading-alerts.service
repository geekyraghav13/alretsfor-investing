[Unit]
Description=Trading Alerts — Congress trades + SEC 13D/13G watcher
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/trading-alerts
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-%h/trading-alerts/.env
ExecStart=%h/trading-alerts/.venv/bin/python -m alerts.main
Restart=on-failure
RestartSec=30

[Install]
WantedBy=default.target
